# Postgres (para prisma db push)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hydra_creator?schema=public"

# Analyzer
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto            # auto | cuda | cpu
MAX_VIDEO_DURATION_SEC=14400   # 4 horas

# Transform
USE_CUDA=auto                  # auto | true | false
